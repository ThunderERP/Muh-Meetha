// ThunderERP — Prisma Schema v3
// Implements: Multi-tenancy, RBAC, Audit Logging, Module Registry,
//             Feature Flags, Subscriptions, Notifications, Events,
//             Workflows, Inventory, and all ERP foundation tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  DEVELOPER_ADMIN
  BUSINESS_OWNER
  SALES_MANAGER
  SALES_STAFF
  INVENTORY_MANAGER
  FINANCE_MANAGER
  ACCOUNTANT
  CRM_SUPPORT
  REFUND_HANDLER
  MANAGER
}

enum TenantPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum ModuleKey {
  INVENTORY
  SALES
  PURCHASE
  ACCOUNTING
  CRM
  HRMS
  PAYROLL
  MANUFACTURING
  POS
  ASSET_MANAGEMENT
  SERVICE_MANAGEMENT
  PROJECT_MANAGEMENT
  ANALYTICS
  COMPLIANCE
  WORKFLOW_AUTOMATION
}

enum ModuleStatus {
  ACTIVE
  INACTIVE
  TRIAL
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
  EXPORT
  MANAGE
  APPROVE
}

enum WorkflowStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum StockMovementType {
  INWARD
  OUTWARD
  ADJUSTMENT
  RESERVATION
  RESERVATION_RELEASE
}

enum FileEntityType {
  PRODUCT
  CUSTOMER
  SUPPLIER
  ORDER
  PURCHASE
  RETURN
  COMPLAINT
  INVOICE
  USER
  COMPANY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
}

enum PurchaseStatus {
  DRAFT
  PENDING
  APPROVED
  RECEIVED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
  CANCELLED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum ReturnType {
  REFUND
  RETURN
  REPLACEMENT
}

enum PaymentMethod {
  CASH
  UPI
  BANK
  CARD
  CREDIT
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum TrackingStatus {
  PENDING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
  ACTIVATE
  DEACTIVATE
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE FOUNDATION: TENANT / COMPANY
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id               Int        @id @default(autoincrement())
  slug             String     @unique
  name             String
  legalName        String?    @map("legal_name")
  plan             TenantPlan @default(STARTER)
  isActive         Boolean    @default(true)   @map("is_active")
  maxUsers         Int        @default(10)     @map("max_users")
  storageQuotaMb   Int        @default(500)    @map("storage_quota_mb")
  phone            String?
  website          String?
  email            String?
  gstin            String?
  pan              String?
  cin              String?
  industry         String?
  businessType     String?    @map("business_type")
  country          String     @default("India")
  state            String?
  city             String?
  pincode          String?
  address          String?    @db.Text
  timezone         String     @default("Asia/Kolkata")
  currency         String     @default("INR")
  fiscalYearStart  Int        @default(4) @map("fiscal_year_start") // month 1-12
  tosAcceptedAt    DateTime?  @map("tos_accepted_at")
  tosAcceptedIp    String?    @map("tos_accepted_ip")
  isEmailVerified  Boolean    @default(false)  @map("is_email_verified")
  trialEndsAt      DateTime?  @map("trial_ends_at")
  createdAt        DateTime   @default(now())  @map("created_at")
  updatedAt        DateTime   @updatedAt       @map("updated_at")

  users              User[]
  companyModules     CompanyModule[]
  featureFlags       FeatureFlag[]
  subscriptions      Subscription[]
  notifications      Notification[]
  activities         Activity[]
  auditLogs          AuditLog[]
  workflowInstances  WorkflowInstance[]
  files              FileRecord[]
  companySettings    CompanySetting[]
  termsAcceptances   TermsAcceptance[]
  jobQueue           JobQueue[]
  events             DomainEvent[]

  // Inventory domain
  products           Product[]
  suppliers          Supplier[]

  @@index([slug])
  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String
  passwordHash String   @map("password_hash")
  role         Role     @default(SALES_STAFF)
  isActive     Boolean  @default(true)  @map("is_active")
  phone        String?
  jobTitle     String?  @map("job_title")
  avatarUrl    String?  @map("avatar_url")
  lastLoginAt  DateTime? @map("last_login_at")
  lastLoginIp  String?   @map("last_login_ip")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")
  createdBy    Int?      @map("created_by")

  userSettings       UserSettings?
  userPermissions    UserPermission[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  activities         Activity[]
  termsAcceptances   TermsAcceptance[]
  workflowActions    WorkflowAction[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@map("users")
}

model UserSettings {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme                String   @default("light")
  language             String   @default("en")
  dateFormat           String   @default("DD/MM/YYYY")  @map("date_format")
  currency             String   @default("INR")
  timezone             String   @default("Asia/Kolkata")
  notifyOrderUpdates   Boolean  @default(true)  @map("notify_order_updates")
  notifyLowStock       Boolean  @default(true)  @map("notify_low_stock")
  notifyPayments       Boolean  @default(true)  @map("notify_payments")
  notifyReturns        Boolean  @default(true)  @map("notify_returns")
  sidebarCollapsed     Boolean  @default(false) @map("sidebar_collapsed")
  // Inventory display preferences (server-persisted mirror of client store)
  invShowSku           Boolean  @default(true)  @map("inv_show_sku")
  invShowGst           Boolean  @default(true)  @map("inv_show_gst")
  invShowDiscount      Boolean  @default(true)  @map("inv_show_discount")
  invShowReorderLevel  Boolean  @default(true)  @map("inv_show_reorder_level")
  invShowImage         Boolean  @default(true)  @map("inv_show_image")
  invShowMfgDate       Boolean  @default(false) @map("inv_show_mfg_date")
  invShowExpiryDate    Boolean  @default(true)  @map("inv_show_expiry_date")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// RBAC: ROLES, PERMISSIONS
// ─────────────────────────────────────────────────────────────────────────────

model Permission {
  id          Int              @id @default(autoincrement())
  module      ModuleKey
  resource    String           // e.g. "products", "suppliers", "users"
  action      PermissionAction
  description String?

  rolePermissions    RolePermission[]
  userPermissions    UserPermission[]

  @@unique([module, resource, action])
  @@map("permissions")
}

model RolePermission {
  id           Int              @id @default(autoincrement())
  role         Role
  permissionId Int              @map("permission_id")
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           Int        @id @default(autoincrement())
  userId       Int        @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId Int        @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  granted      Boolean    @default(true)  // false = explicit DENY overrides role
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE REGISTRY & SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────────

model CompanyModule {
  id          Int          @id @default(autoincrement())
  tenantId    Int          @map("tenant_id")
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleKey   ModuleKey    @map("module_key")
  status      ModuleStatus @default(INACTIVE)
  activatedAt DateTime?    @map("activated_at")
  expiresAt   DateTime?    @map("expires_at")
  config      Json?        // module-specific config blob
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
  @@map("company_modules")
}

model Subscription {
  id          Int        @id @default(autoincrement())
  tenantId    Int        @map("tenant_id")
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan        TenantPlan
  startsAt    DateTime   @map("starts_at")
  endsAt      DateTime?  @map("ends_at")
  isActive    Boolean    @default(true)  @map("is_active")
  maxUsers    Int        @default(10)    @map("max_users")
  storageMb   Int        @default(500)   @map("storage_mb")
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("subscriptions")
}

model FeatureFlag {
  id          Int      @id @default(autoincrement())
  tenantId    Int?     @map("tenant_id")   // NULL = global
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  enabled     Boolean  @default(false)
  description String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, key])
  @@map("feature_flags")
}

// ─────────────────────────────────────────────────────────────────────────────
// SETTINGS
// ─────────────────────────────────────────────────────────────────────────────

model CompanySetting {
  id        Int    @id @default(autoincrement())
  tenantId  Int    @map("tenant_id")
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module    String // "inventory", "sales", "system" etc.
  key       String
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, module, key])
  @@index([tenantId, module])
  @@map("company_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id         Int                 @id @default(autoincrement())
  tenantId   Int                 @map("tenant_id")
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     Int                 @map("user_id")
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    NotificationChannel @default(IN_APP)
  status     NotificationStatus  @default(PENDING)
  title      String
  body       String              @db.Text
  data       Json?               // action url, entity refs
  readAt     DateTime?           @map("read_at")
  sentAt     DateTime?           @map("sent_at")
  createdAt  DateTime            @default(now()) @map("created_at")

  @@index([tenantId, userId, status])
  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITY FEED
// ─────────────────────────────────────────────────────────────────────────────

model Activity {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      ModuleKey?
  action      String   // human-readable "Created product 'Widget A'"
  entityType  String?  @map("entity_type")
  entityId    Int?     @map("entity_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@index([tenantId, entityType, entityId])
  @@map("activities")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOGS — IMMUTABLE
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id          Int         @id @default(autoincrement())
  tenantId    Int         @map("tenant_id")
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      Int         @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  action      AuditAction
  module      String
  entityType  String      @map("entity_type")
  entityId    Int?        @map("entity_id")
  before      Json?
  after       Json?
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  requestId   String?     @map("request_id")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@index([tenantId, module, entityType])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// DOMAIN EVENTS (Event Bus persistence)
// ─────────────────────────────────────────────────────────────────────────────

model DomainEvent {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventType    String   @map("event_type")   // "ProductCreated", "StockAdded" etc.
  aggregateId  Int?     @map("aggregate_id")
  aggregateType String? @map("aggregate_type")
  payload      Json
  processedAt  DateTime? @map("processed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([tenantId, eventType])
  @@index([tenantId, processedAt])
  @@map("domain_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKFLOW ENGINE
// ─────────────────────────────────────────────────────────────────────────────

model WorkflowDefinition {
  id          Int      @id @default(autoincrement())
  name        String
  module      String
  entityType  String   @map("entity_type")
  triggerOn   String   @map("trigger_on")   // "CREATE", "STATUS_CHANGE" etc.
  steps       Json     // approval chain config
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  instances WorkflowInstance[]

  @@map("workflow_definitions")
}

model WorkflowInstance {
  id           Int            @id @default(autoincrement())
  tenantId     Int            @map("tenant_id")
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  definitionId Int            @map("definition_id")
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id])
  entityType   String         @map("entity_type")
  entityId     Int            @map("entity_id")
  status       WorkflowStatus @default(DRAFT)
  currentStep  Int            @default(0) @map("current_step")
  data         Json?
  startedAt    DateTime       @default(now()) @map("started_at")
  completedAt  DateTime?      @map("completed_at")
  createdBy    Int            @map("created_by")

  actions WorkflowAction[]

  @@index([tenantId, status])
  @@index([tenantId, entityType, entityId])
  @@map("workflow_instances")
}

model WorkflowAction {
  id          Int            @id @default(autoincrement())
  instanceId  Int            @map("instance_id")
  instance    WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  userId      Int            @map("user_id")
  user        User           @relation(fields: [userId], references: [id])
  step        Int
  action      String         // "APPROVE", "REJECT", "COMMENT"
  comments    String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([instanceId])
  @@map("workflow_actions")
}

// ─────────────────────────────────────────────────────────────────────────────
// BACKGROUND JOB QUEUE
// ─────────────────────────────────────────────────────────────────────────────

model JobQueue {
  id          Int       @id @default(autoincrement())
  tenantId    Int?      @map("tenant_id")
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  jobType     String    @map("job_type")   // "SEND_EMAIL", "EXPORT_CSV" etc.
  status      JobStatus @default(PENDING)
  payload     Json
  result      Json?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  error       String?   @db.Text
  scheduledAt DateTime  @default(now()) @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([status, scheduledAt])
  @@index([tenantId, jobType])
  @@map("job_queue")
}

// ─────────────────────────────────────────────────────────────────────────────
// FILE MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

model FileRecord {
  id           Int            @id @default(autoincrement())
  tenantId     Int            @map("tenant_id")
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType   FileEntityType @map("entity_type")
  entityId     Int            @map("entity_id")
  fieldName    String         @map("field_name")
  originalName String         @map("original_name")
  mimeType     String         @map("mime_type")
  sizeBytes    Int            @map("size_bytes")
  storageKey   String         @map("storage_key")
  url          String
  driver       String         @default("local")  // "local" | "s3" | "supabase"
  isActive     Boolean        @default(true)  @map("is_active")
  uploadedAt   DateTime       @default(now()) @map("uploaded_at")
  uploadedBy   Int            @map("uploaded_by")

  @@index([tenantId, entityType, entityId])
  @@index([tenantId])
  @@map("file_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// TERMS / COMPLIANCE
// ─────────────────────────────────────────────────────────────────────────────

model TermsAcceptance {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    Int      @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  version     String
  acceptedAt  DateTime @default(now()) @map("accepted_at")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")

  @@index([userId])
  @@index([tenantId])
  @@map("terms_acceptances")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id                 Int       @id @default(autoincrement())
  tenantId           Int       @map("tenant_id")
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  sku                String?
  barcode            String?
  category           String?
  subcategory        String?
  brand              String?
  unit               String    @default("Piece")
  hsn                String?   // HSN code for GST
  price              Decimal   @db.Decimal(12, 2)
  purchasePrice      Decimal?  @db.Decimal(12, 2) @map("purchase_price")
  gstPercentage      Decimal   @db.Decimal(5, 2)  @default(18.00) @map("gst_percentage")
  discountPercentage Decimal   @db.Decimal(5, 2)  @default(0.00)  @map("discount_percentage")
  description        String?   @db.Text
  expiryDate         DateTime? @map("expiry_date")
  manufacturingDate  DateTime? @map("manufacturing_date")
  imageUrl           String?   @map("image_url")
  isActive           Boolean   @default(true)  @map("is_active")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt      @map("updated_at")
  createdBy          Int       @map("created_by")
  updatedBy          Int?      @map("updated_by")

  inventory      Inventory?
  stockMovements StockMovement[]
  orderItems     OrderItem[]
  purchaseItems  PurchaseItem[]
  returnItems    ReturnItem[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, sku])
  @@index([tenantId, isActive])
  @@map("products")
}

model Inventory {
  id           Int      @id @default(autoincrement())
  productId    Int      @unique @map("product_id")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  availableQty Int      @default(0) @map("available_qty")
  reservedQty  Int      @default(0) @map("reserved_qty")
  reorderLevel Int      @default(10) @map("reorder_level")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("inventory")
}

model StockMovement {
  id            Int               @id @default(autoincrement())
  productId     Int               @map("product_id")
  product       Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  type          StockMovementType
  quantity      Int
  stockBefore   Int               @map("stock_before")
  stockAfter    Int               @map("stock_after")
  referenceType String            @map("reference_type")
  referenceId   Int?              @map("reference_id")
  notes         String?           @db.Text
  createdAt     DateTime          @default(now()) @map("created_at")
  createdBy     Int               @map("created_by")

  @@index([productId])
  @@index([productId, createdAt])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

model Supplier {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String?  // supplier reference code
  phone       String?
  email       String?
  address     String?  @db.Text
  city        String?
  state       String?
  pincode     String?
  gstin       String?
  pan         String?
  bankName    String?  @map("bank_name")
  bankAccount String?  @map("bank_account")
  bankIfsc    String?  @map("bank_ifsc")
  notes       String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   Int      @map("created_by")

  purchases Purchase[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("suppliers")
}

// ─────────────────────────────────────────────────────────────────────────────
// SALES MODULE (schema only — no UI yet)
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id                     Int           @id @default(autoincrement())
  tenantId               Int           @map("tenant_id")
  name                   String
  phone                  String
  email                  String?
  address                String?       @db.Text
  city                   String?
  state                  String?
  pincode                String?
  gstin                  String?
  preferredPaymentMethod PaymentMethod? @map("preferred_payment_method")
  creditLimit            Decimal?      @db.Decimal(12, 2) @map("credit_limit")
  isActive               Boolean       @default(true) @map("is_active")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  createdBy              Int           @map("created_by")

  orders     Order[]
  complaints Complaint[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("customers")
}

model Order {
  id          Int         @id @default(autoincrement())
  tenantId    Int         @map("tenant_id")
  customerId  Int         @map("customer_id")
  customer    Customer    @relation(fields: [customerId], references: [id])
  orderDate   DateTime    @default(now()) @map("order_date")
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(12, 2) @default(0) @map("total_amount")
  discount    Decimal     @db.Decimal(12, 2) @default(0)
  taxAmount   Decimal     @db.Decimal(12, 2) @default(0) @map("tax_amount")
  notes       String?     @db.Text
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  createdBy   Int         @map("created_by")
  updatedBy   Int?        @map("updated_by")

  items    OrderItem[]
  invoice  Invoice?
  tracking Tracking?
  returns  ReturnItem[]

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@map("orders")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int     @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int     @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2) @map("unit_price")
  gstPct      Decimal @db.Decimal(5, 2)  @map("gst_pct")
  discountPct Decimal @db.Decimal(5, 2)  @default(0) @map("discount_pct")
  lineTotal   Decimal @db.Decimal(12, 2) @map("line_total")

  @@index([orderId])
  @@map("order_items")
}

model Tracking {
  id           Int            @id @default(autoincrement())
  orderId      Int            @unique @map("order_id")
  order        Order          @relation(fields: [orderId], references: [id])
  status       TrackingStatus @default(PENDING)
  trackingDate DateTime?      @map("tracking_date")
  address      String?        @db.Text
  updatedAt    DateTime       @updatedAt @map("updated_at")
  updatedBy    Int?           @map("updated_by")

  @@map("tracking")
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASE MODULE (schema only — no UI yet)
// ─────────────────────────────────────────────────────────────────────────────

model Purchase {
  id                   Int            @id @default(autoincrement())
  tenantId             Int            @map("tenant_id")
  supplierId           Int            @map("supplier_id")
  supplier             Supplier       @relation(fields: [supplierId], references: [id])
  purchaseDate         DateTime       @default(now()) @map("purchase_date")
  expectedDeliveryDate DateTime?      @map("expected_delivery_date")
  status               PurchaseStatus @default(DRAFT)
  totalAmount          Decimal        @db.Decimal(12, 2) @default(0) @map("total_amount")
  notes                String?        @db.Text
  poNumber             String?        @map("po_number")
  approvedBy           Int?           @map("approved_by")
  approvedAt           DateTime?      @map("approved_at")
  isActive             Boolean        @default(true) @map("is_active")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  createdBy            Int            @map("created_by")

  items PurchaseItem[]

  @@index([tenantId])
  @@index([tenantId, supplierId])
  @@map("purchases")
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int      @map("purchase_id")
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  Int      @map("product_id")
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2) @map("unit_price")
  lineTotal  Decimal  @db.Decimal(12, 2) @map("line_total")

  @@index([purchaseId])
  @@map("purchase_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// FINANCE MODULE (schema only — no UI yet)
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id              Int           @id @default(autoincrement())
  tenantId        Int           @map("tenant_id")
  orderId         Int           @unique @map("order_id")
  order           Order         @relation(fields: [orderId], references: [id])
  invoiceDate     DateTime      @default(now()) @map("invoice_date")
  taxAmount       Decimal       @db.Decimal(12, 2) @map("tax_amount")
  deliveryCharges Decimal       @db.Decimal(12, 2) @default(0) @map("delivery_charges")
  totalAmount     Decimal       @db.Decimal(12, 2) @map("total_amount")
  paidAmount      Decimal       @db.Decimal(12, 2) @default(0) @map("paid_amount")
  status          InvoiceStatus @default(PENDING)
  dueDate         DateTime?     @map("due_date")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  payments Payment[]

  @@index([tenantId])
  @@map("invoices")
}

model Payment {
  id            Int           @id @default(autoincrement())
  invoiceId     Int           @map("invoice_id")
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  referenceId   String?       @map("reference_id")
  date          DateTime      @default(now())
  notes         String?       @db.Text
  createdBy     Int           @map("created_by")

  transaction Transaction?

  @@index([invoiceId])
  @@map("payments")
}

model Transaction {
  id          Int             @id @default(autoincrement())
  paymentId   Int             @unique @map("payment_id")
  payment     Payment         @relation(fields: [paymentId], references: [id])
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  accountCode String          @map("account_code")
  status      String          @default("POSTED")
  entryDate   DateTime        @default(now()) @map("entry_date")
  createdBy   Int             @map("created_by")

  @@map("transactions")
}

model ReturnItem {
  id         Int          @id @default(autoincrement())
  tenantId   Int          @map("tenant_id")
  orderId    Int          @map("order_id")
  order      Order        @relation(fields: [orderId], references: [id])
  productId  Int          @map("product_id")
  product    Product      @relation(fields: [productId], references: [id])
  quantity   Int
  type       ReturnType
  reason     String       @db.Text
  status     ReturnStatus @default(REQUESTED)
  refundAmt  Decimal?     @db.Decimal(12, 2) @map("refund_amt")
  resolvedAt DateTime?    @map("resolved_at")
  resolvedBy Int?         @map("resolved_by")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  createdBy  Int          @map("created_by")

  @@index([tenantId])
  @@index([orderId])
  @@map("return_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM MODULE (schema only — no UI yet)
// ─────────────────────────────────────────────────────────────────────────────

model Lead {
  id                    Int       @id @default(autoincrement())
  tenantId              Int       @map("tenant_id")
  name                  String
  phone                 String?
  email                 String?
  source                String?
  status                String    @default("NEW")
  notes                 String?   @db.Text
  assignedTo            Int?      @map("assigned_to")
  convertedToCustomerId Int?      @map("converted_to_customer_id")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  createdBy             Int       @map("created_by")

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("leads")
}

model Complaint {
  id          Int       @id @default(autoincrement())
  tenantId    Int       @map("tenant_id")
  customerId  Int       @map("customer_id")
  customer    Customer  @relation(fields: [customerId], references: [id])
  subject     String
  description String    @db.Text
  status      String    @default("OPEN")
  priority    String    @default("MEDIUM")
  resolvedAt  DateTime? @map("resolved_at")
  resolvedBy  Int?      @map("resolved_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   Int       @map("created_by")

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@map("complaints")
}
